# Local development default:
AGMS_DATABASE_URL=sqlite:////opt/anime-gallery/backend/anime_gallery.db
# Production MySQL example:
# AGMS_DATABASE_URL=mysql+pymysql://anime_gallery:change-this-db-password@127.0.0.1:3306/anime_gallery?charset=utf8mb4
AGMS_STORAGE_PATH=/opt/anime-gallery/storage
AGMS_ADMIN_USERNAME=admin
AGMS_ADMIN_PASSWORD=change-this-password
# Generated automatically by /install. If bypassing the setup page, generate one:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
# AGMS_AUTH_SECRET=
# Generated automatically by /install. Used by server-side scripts with Authorization: Bearer <key>.
# AGMS_API_KEYS=default:agms_change_this_long_random_key
AGMS_AUTH_TOKEN_TTL_SECONDS=43200
AGMS_COOKIE_SECURE=false
AGMS_MAX_UPLOAD_SIZE=104857600
AGMS_PREVIEW_MAX_SIZE=1600
AGMS_THUMBNAIL_MAX_SIZE=480
# Linux systemd deployments should keep this enabled so panel updates run in the independent updater service.
# Without AGMS_UPDATE_TRIGGER_COMMAND, the panel allows download verification only and disables real upgrades.
# AGMS_UPDATE_TRIGGER_COMMAND=sudo -n systemctl start anime-gallery-updater@{task_id}.service
AGMS_UPDATE_SERVICE_NAME=anime-gallery
AGMS_UPDATE_HEALTH_URL=http://127.0.0.1:8000/api/health
AGMS_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","https://gallery.example.com"]
